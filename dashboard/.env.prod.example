# Database
DB_HOST=db
DB_PORT=3306
DB_USER=root
DB_PASS=changeme_strong_password
DB_NAME=cosmic

# Auth
ADMIN_USER=admin
ADMIN_PASS_HASH=$2a$12$...  # Generate with: node -e "require('bcryptjs').hash('yourpass',12).then(console.log)"
JWT_SECRET=changeme_random_64_char_string

# Cosmic server root (path inside container or on host)
COSMIC_ROOT=/cosmic

# Cloudflare Turnstile (captcha)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x...  # From https://dash.cloudflare.com → Turnstile
TURNSTILE_SECRET_KEY=0x...

# AI Game Master (OpenRouter)
OPENROUTER_API_KEY=sk-or-v1-...
GM_MODEL=nousresearch/hermes-3-llama-3.1-405b  # Optional, defaults to this
